{
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictFunctionTypes": true,
    "strictPropertyInitialization": true,
    "strictBindCallApply": true,
    "noImplicitThis": true,
    "noImplicitReturns": true,
    "alwaysStrict": true,
    "esModuleInterop": true,
    "checkJs": true,
    "allowJs": true,
    "noEmit": true,
    "lib": ["DOM", "ESNext"],
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler"
  },
  "include": ["src"]
}
