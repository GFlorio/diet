{
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictFunctionTypes": true,
    "strictPropertyInitialization": true,
    "strictBindCallApply": true,
    "noImplicitThis": true,
    "noImplicitReturns": true,
    "alwaysStrict": true,
    "esModuleInterop": true,
    "checkJs": true,
    "allowJs": true,
    "declaration": true,
    "lib": ["DOM", "ESNext"],
    "types": ["vite/client", "vite-plugin-pwa/client"],
    "target": "ES2023",
    "module": "node16",
    "moduleResolution": "node16",
    "outDir": "dist"
  },
  "include": [
    "./frontend/src/**/*.js"
  ],
  "verbose": true
}
